# Per-app parameters for the shared shell-core release/build scripts.
# Each consuming app commits its own scripts/tooling.env (TRACKED) with these three values; the
# generic scripts (release.sh / gen-latest-json.sh / install-app.sh) source it. Everything else is
# derived (VERSION_FILE=${TAURI_CRATE_DIR}/Cargo.toml, bundle=${APP_NAME}.app, zip/tarball names).

# Product name — the Tauri bundle is ${APP_NAME}.app; used in messages, `quit app`, latest.json.
APP_NAME=myapp

# Path (from repo root) to the crate that runs `cargo tauri build` and single-sources `version`.
# e.g. warden: crates/warden-app   ·   curator: src-tauri
TAURI_CRATE_DIR=src-tauri

# GitHub owner/repo for the updater endpoint + release-download URLs (case-canonical, one place).
UPDATER_REPO=lockyc/myapp
